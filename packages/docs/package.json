{
  "name": "@inth/docs",
  "version": "0.0.0",
  "description": "Framework-neutral docs pipeline tooling for Inth public docs",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js"
    },
    "./convert": {
      "types": "./dist/convert/index.d.ts",
      "import": "./dist/convert/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./search/node": {
      "types": "./dist/search/node-index.d.ts",
      "import": "./dist/search/node-index.js"
    },
    "./search/ai": {
      "types": "./dist/search/ai-index.d.ts",
      "import": "./dist/search/ai-index.js"
    },
    "./search/bash": {
      "types": "./dist/search/bash-index.d.ts",
      "import": "./dist/search/bash-index.js"
    },
    "./search/vercel": {
      "types": "./dist/search/vercel-index.d.ts",
      "import": "./dist/search/vercel-index.js"
    },
    "./search/tanstack": {
      "types": "./dist/search/tanstack-index.d.ts",
      "import": "./dist/search/tanstack-index.js"
    },
    "./search/cloudflare": {
      "types": "./dist/search/cloudflare-index.d.ts",
      "import": "./dist/search/cloudflare-index.js"
    },
    "./lint": {
      "types": "./dist/lint/index.d.ts",
      "import": "./dist/lint/index.js"
    }
  },
  "bin": {
    "inth-docs-lint": "./dist/lint/cli.js"
  },
  "files": [
    "dist",
    "agent-docs",
    "README.md"
  ],
  "scripts": {
    "build": "bun run docs:agent && tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "docs:agent": "bun run docs:agent:generate",
    "docs:agent:generate": "bun run ./scripts/generate-agent-docs.ts",
    "lint": "ultracite check src",
    "test": "vitest run"
  },
  "dependencies": {
    "decode-named-character-reference": "1.3.0",
    "fast-glob": "3.3.3",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "json5": "2.2.3",
    "mdast-util-compact": "5.0.0",
    "mdast-util-mdx": "3.0.0",
    "mdast-util-mdx-jsx": "3.2.0",
    "mdast-util-mdxjs-esm": "2.0.1",
    "mdast-util-to-markdown": "2.1.2",
    "mdast-util-to-string": "4.0.0",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "unified": "11.0.5",
    "unist-builder": "4.0.0",
    "unist-util-is": "6.0.1",
    "unist-util-visit": "5.1.0",
    "valibot": "1.0.0"
  },
  "devDependencies": {
    "@cloudflare/tanstack-ai": "^0.1.7",
    "@repo/typescript-config": "*",
    "@tanstack/ai": "^0.13.0",
    "@types/mdast": "4.0.4",
    "@types/node": "^22.10.0",
    "ai": "^6.0.168",
    "bash-tool": "1.3.16",
    "just-bash": "2.14.2",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@cloudflare/tanstack-ai": ">=0.1.7",
    "@tanstack/ai": ">=0.13.0",
    "ai": ">=6.0.0",
    "bash-tool": ">=1.3.16",
    "just-bash": ">=2.14.2",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/tanstack-ai": {
      "optional": true
    },
    "@tanstack/ai": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "bash-tool": {
      "optional": true
    },
    "just-bash": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
