{
  "name": "leadtype",
  "version": "0.0.0",
  "description": "Framework-neutral docs pipeline tooling for MDX, LLM bundles, and search",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js"
    },
    "./convert": {
      "types": "./dist/convert/index.d.ts",
      "import": "./dist/convert/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./search/node": {
      "types": "./dist/search/node-index.d.ts",
      "import": "./dist/search/node-index.js"
    },
    "./search/ai": {
      "types": "./dist/search/ai-index.d.ts",
      "import": "./dist/search/ai-index.js"
    },
    "./search/bash": {
      "types": "./dist/search/bash-index.d.ts",
      "import": "./dist/search/bash-index.js"
    },
    "./search/vercel": {
      "types": "./dist/search/vercel-index.d.ts",
      "import": "./dist/search/vercel-index.js"
    },
    "./search/tanstack": {
      "types": "./dist/search/tanstack-index.d.ts",
      "import": "./dist/search/tanstack-index.js"
    },
    "./search/cloudflare": {
      "types": "./dist/search/cloudflare-index.d.ts",
      "import": "./dist/search/cloudflare-index.js"
    },
    "./lint": {
      "types": "./dist/lint/index.d.ts",
      "import": "./dist/lint/index.js"
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist",
    "docs",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c && bun run docs:generate",
    "dev": "rollup -c -w",
    "check-types": "tsgo --noEmit",
    "docs:generate": "bun run ./scripts/generate-docs.ts",
    "lint": "ultracite check src",
    "test": "vitest run"
  },
  "dependencies": {
    "decode-named-character-reference": "1.3.0",
    "fast-glob": "3.3.3",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "json5": "2.2.3",
    "mdast-util-compact": "5.0.0",
    "mdast-util-mdx": "3.0.0",
    "mdast-util-mdx-jsx": "3.2.0",
    "mdast-util-mdxjs-esm": "2.0.1",
    "mdast-util-to-markdown": "2.1.2",
    "mdast-util-to-string": "4.0.0",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "unified": "11.0.5",
    "unist-builder": "4.0.0",
    "unist-util-is": "6.0.1",
    "unist-util-visit": "5.1.0",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@cloudflare/tanstack-ai": "^0.1.7",
    "@repo/typescript-config": "workspace:*",
    "@tanstack/ai": "^0.15.0",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@types/mdast": "4.0.4",
    "@types/node": "^22.0.0",
    "ai": "^6.0.177",
    "bash-tool": "1.3.16",
    "just-bash": "2.14.5",
    "rollup": "^4.40.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@cloudflare/tanstack-ai": ">=0.1.7",
    "@tanstack/ai": ">=0.15.0",
    "ai": ">=6.0.0",
    "bash-tool": ">=1.3.16",
    "just-bash": ">=2.14.5",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/tanstack-ai": {
      "optional": true
    },
    "@tanstack/ai": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "bash-tool": {
      "optional": true
    },
    "just-bash": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
