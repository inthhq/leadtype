    "./search/bash": {
      "types": "./dist/search/bash-index.d.ts",
      "import": "./dist/search/bash-index.js"
    },
    "./search/vercel": {
      "types": "./dist/search/vercel-index.d.ts",
      "import": "./dist/search/vercel-index.js"
    },
    "./search/tanstack": {
      "types": "./dist/search/tanstack-index.d.ts",
      "import": "./dist/search/tanstack-index.js"
    },
    "./search/cloudflare": {
      "types": "./dist/search/cloudflare-index.d.ts",
      "import": "./dist/search/cloudflare-index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit/index.d.ts",
      "import": "./dist/sveltekit/index.js"
    },
    "./tanstack-start": {
      "types": "./dist/tanstack-start/index.d.ts",
      "import": "./dist/tanstack-start/index.js"
    },
    "./lint": {
      "types": "./dist/lint/index.d.ts",
      "import": "./dist/lint/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./nlweb": {
      "types": "./dist/nlweb/index.d.ts",
      "import": "./dist/nlweb/index.js"
    },
    "./webmcp": {
      "types": "./dist/webmcp/index.d.ts",
      "import": "./dist/webmcp/index.js"
    },
    "./webmcp/react": {
      "types": "./dist/webmcp/react.d.ts",
      "import": "./dist/webmcp/react.js"
    },
    "./webmcp/vue": {
      "types": "./dist/webmcp/vue.d.ts",
      "import": "./dist/webmcp/vue.js"
    },
    "./webmcp/svelte": {
      "types": "./dist/webmcp/svelte.d.ts",
      "import": "./dist/webmcp/svelte.js"
    },
    "./score": {
      "types": "./dist/score/index.d.ts",
      "import": "./dist/score/index.js"
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist",
    "docs",
    "AGENTS.md",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c --configPlugin rollup-plugin-esbuild --silent && bun run --silent docs:generate",
    "dev": "rollup -c --configPlugin rollup-plugin-esbuild -w",
    "check-types": "tsgo --noEmit",
    "docs:generate": "bun run ./scripts/generate-docs.ts",
    "lint": "ultracite check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/mdast": "4.0.4",
    "json5": "2.2.3",
    "mdast-util-to-string": "4.0.0",
    "satteri": "^0.9.3",
    "tinyglobby": "0.2.16",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "valibot": "1.4.0",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cloudflare/tanstack-ai": "^0.1.7",
