{
  "name": "leadtype",
  "version": "0.3.1",
  "description": "Framework-neutral docs pipeline tooling for MDX, LLM bundles, and search",
  "type": "module",
  "license": "MIT",
  "homepage": "https://leadtype.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inthhq/leadtype.git",
    "directory": "packages/leadtype"
  },
  "bugs": {
    "url": "https://github.com/inthhq/leadtype/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./mdx": {
      "types": "./dist/mdx/index.d.ts",
      "import": "./dist/mdx/index.js"
    },
    "./mdx/source": {
      "types": "./dist/mdx/source.d.ts",
      "import": "./dist/mdx/source.js",
      "default": "./dist/mdx/source.js"
    },
    "./mdx/openapi": {
      "types": "./dist/mdx/openapi.d.ts",
      "import": "./dist/mdx/openapi.js",
      "default": "./dist/mdx/openapi.js"
    },
    "./feed": {
      "types": "./dist/feed/index.d.ts",
      "import": "./dist/feed/index.js"
    },
    "./fumadocs": {
      "types": "./dist/fumadocs/index.d.ts",
      "import": "./dist/fumadocs/index.js"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./nuxt": {
      "types": "./dist/nuxt/index.d.ts",
      "import": "./dist/nuxt/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./next/client": {
      "types": "./dist/next/client.d.ts",
      "import": "./dist/next/client.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "import": "./dist/openapi/index.js"
    },
    "./transformers": {
      "types": "./dist/transformers.d.ts",
      "import": "./dist/transformers.js"
    },
    "./convert": {
      "types": "./dist/convert/index.d.ts",
      "import": "./dist/convert/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./llm/readability": {
      "types": "./dist/llm/readability.d.ts",
      "import": "./dist/llm/readability.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js"
    },
    "./redirects": {
      "types": "./dist/redirects/index.d.ts",
