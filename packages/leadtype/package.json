      "types": "./dist/redirects/node-index.d.ts",
      "import": "./dist/redirects/node-index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./search/client": {
      "types": "./dist/search/client.d.ts",
      "import": "./dist/search/client.js"
    },
    "./search/react": {
      "types": "./dist/search/react.d.ts",
      "import": "./dist/search/react.js"
    },
    "./search/vue": {
      "types": "./dist/search/vue.d.ts",
      "import": "./dist/search/vue.js"
    },
    "./search/svelte": {
      "types": "./dist/search/svelte.d.ts",
      "import": "./dist/search/svelte.js"
    },
    "./search/node": {
      "types": "./dist/search/node-index.d.ts",
      "import": "./dist/search/node-index.js"
    },
    "./search/ai": {
      "types": "./dist/search/ai-index.d.ts",
