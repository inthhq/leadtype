#!/bin/sh
# Note: errors handled explicitly so FORMAT_EXIT_CODE is reachable.

# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# Run formatter first so tests run against the post-fix, restaged tree.
if [ -n "$STAGED_FILES" ]; then
  bun x ultracite fix
  FORMAT_EXIT_CODE=$?

  # Re-stage files that were already staged
  echo "$STAGED_FILES" | while IFS= read -r file; do
    if [ -f "$file" ]; then
      git add "$file"
    fi
  done

  if [ $FORMAT_EXIT_CODE -ne 0 ]; then
    echo "Ultracite found issues that could not be auto-fixed."
    exit $FORMAT_EXIT_CODE
  fi

  echo "✨ Files formatted by Ultracite"
fi

# Run tests against the final tree that will be committed. Real-docs fixtures
# are ignored by Git, but Bun would still discover downstream repo tests there.
bun test --pass-with-no-tests --path-ignore-patterns 'apps/*/content-fixtures/**' || exit $?
