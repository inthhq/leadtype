{
  "name": "c15t-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:generate": "leadtype generate --src ../.. --docs-dir docs --out public --base-url http://localhost:5173 --json",
    "dev": "bun run --filter leadtype build && bun run docs:generate && PORTLESS_PORT=443 PORTLESS_HTTPS=1 portless run vite dev",
    "build": "bun run --filter leadtype build && bun run docs:generate && vite build",
    "preview": "PORTLESS_PORT=443 PORTLESS_HTTPS=1 portless run vite preview",
    "check-types": "bun run --filter leadtype build && bun run docs:generate && tsgo --noEmit",
    "setup:real": "bun run pipeline:setup-real",
    "generate:real": "bun run pipeline:generate-real",
    "test:real": "bun run pipeline:test-real",
    "llm:real": "bun run pipeline:llm-real",
    "pipeline:setup-real": "bun run scripts/setup-real-content.ts",
    "pipeline:generate-real": "bun run pipeline:setup-real && bun run scripts/generate-real.ts",
    "pipeline:test-real": "bun run scripts/test-real.ts",
    "pipeline:llm-real": "bun run scripts/llm-generate-real.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@vitejs/plugin-react": "^6.0.1",
    "leadtype": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.5.0",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
