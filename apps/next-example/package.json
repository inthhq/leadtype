{
  "name": "next-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:generate": "bun ../../packages/leadtype/dist/cli.js generate --src . --out public --base-url http://localhost:3000 --sync --json",
    "docs:prepare": "bun run docs:generate && bun run scripts/build-mdx-map.mjs",
    "dev": "bun run --filter leadtype build && bun run docs:prepare && PORTLESS_PORT=443 PORTLESS_HTTPS=1 portless run next dev --turbopack",
    "build": "bun run --filter leadtype build && bun run docs:prepare && next build --webpack",
    "start": "PORTLESS_PORT=443 PORTLESS_HTTPS=1 portless run next start",
    "check-types": "bun run --filter leadtype build && bun run docs:prepare && tsgo --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@streamdown/mermaid": "^1.0.2",
    "clsx": "^2.1.1",
    "leadtype": "workspace:*",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3"
  }
}
