{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "leadtype": ["./packages/leadtype/src/index.ts"],
      "leadtype/*": ["./packages/leadtype/src/*/index.ts"]
    }
  },
  "include": ["docs/**/*.ts"]
}
