{
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "leadtype": "workspace:*",
    "@mdx-js/react": "^3.1.1",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "husky": "^9.1.7",
    "turbo": "^2.9.12",
    "typescript": "6.0.3",
    "ultracite": "7.6.5"
  },
  "name": "leadtype-monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=example",
    "lint": "turbo run lint",
    "format": "ultracite fix",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "version:snapshot": "changeset version --snapshot && bun install",
    "release": "bun run build && bun scripts/resolve-workspace-deps.ts && changeset publish",
    "release:snapshot": "bun run build && bun scripts/resolve-workspace-deps.ts && changeset publish --tag snapshot"
  },
  "workspaces": [
    "apps/*",
    "evals",
    "packages/*"
  ],
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.11"
}
