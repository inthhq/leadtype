{
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "ultracite": "7.6.0"
  },
  "name": "foobar",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
