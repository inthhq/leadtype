{
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@inth/docs": "workspace:*",
    "@mdx-js/react": "^3.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "ultracite": "7.6.0"
  },
  "name": "suva",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=example",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "version:snapshot": "changeset version --snapshot && bun install",
    "release": "bun run build && bun scripts/resolve-workspace-deps.ts && changeset publish",
    "release:snapshot": "bun run build && bun scripts/resolve-workspace-deps.ts && changeset publish --tag snapshot"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
